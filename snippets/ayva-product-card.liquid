{%- comment -%}
  Shared AYVA product card used by "Complete the Look" and "Charms Grid".

  Accepts:
  - product: product object
  - variant_class: 'ctl' or 'charms' — scopes CSS prefix (ayva-ctl__ / ayva-charms__)
  - button_label: text for quick-add button ('Add' / 'Quick add +')
  - image_widths: responsive widths attr (e.g. '200,400,600')
  - image_sizes: sizes attr
{%- endcomment -%}
{%- liquid
  assign v = product.selected_or_first_available_variant
  assign p_on_sale = false
  if v.compare_at_price and v.compare_at_price > v.price
    assign p_on_sale = true
  endif
-%}
<article class="ayva-{{ variant_class }}__card">
  <a href="{{ product.url }}" class="ayva-{{ variant_class }}__media" aria-label="{{ product.title | escape }}">
    {%- if product.featured_image -%}
      {{
        product.featured_image
        | image_url: width: 600
        | image_tag:
          loading: 'lazy',
          widths: image_widths | default: '200,400,600',
          sizes: image_sizes | default: '(min-width: 990px) 25vw, 50vw',
          alt: product.title | escape
      }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}
  </a>
  <a href="{{ product.url }}" class="ayva-{{ variant_class }}__title">{{ product.title | escape }}</a>
  <div class="ayva-{{ variant_class }}__price">
    {%- if p_on_sale -%}
      <span class="ayva-price__sale">{{ v.price | money }}</span>
      <span class="ayva-price__compare">{{ v.compare_at_price | money }}</span>
    {%- else -%}
      <span class="ayva-price__sale">{{ v.price | money }}</span>
    {%- endif -%}
  </div>
  <product-form class="ayva-{{ variant_class }}__form">
    {%- form 'product', product, id: null, class: 'ayva-quickadd', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
      <input type="hidden" name="id" value="{{ v.id }}" class="product-variant-id" {% unless v.available %}disabled{% endunless %}>
      <button
        type="submit"
        name="add"
        class="ayva-btn ayva-btn--outline ayva-btn--sm product-form__submit"
        {% unless v.available %}disabled{% endunless %}
      >
        <span>{% if v.available %}{{ button_label | default: 'Add' }}{% else %}Sold Out{% endif %}</span>
      </button>
    {%- endform -%}
  </product-form>
</article>
