{%- liquid
  assign items = section.settings.collection.products | default: recommendations.products
  assign limit = section.settings.products_to_show | default: 3
-%}

<section class="ayva-ctl">
  <div class="ayva-ctl__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="ayva-ctl__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="ayva-ctl__list">
      {%- for p in items limit: limit -%}
        {%- if p.id == product.id -%}{%- continue -%}{%- endif -%}
        {%- render 'ayva-product-card',
          product: p,
          variant_class: 'ctl',
          button_label: 'Add',
          image_widths: '200,400,600',
          image_sizes: '(min-width: 990px) 25vw, 50vw'
        -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AYVA Complete the Look",
  "tag": "section",
  "class": "section ayva-ctl-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Complete the look:" },
    { "type": "collection", "id": "collection", "label": "Product source collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 6, "step": 1, "default": 3 }
  ],
  "presets": [
    { "name": "AYVA Complete the Look" }
  ]
}
{% endschema %}
