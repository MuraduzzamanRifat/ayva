{{ 'ayva-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign items = section.settings.collection.products | default: recommendations.products
  assign limit = section.settings.products_to_show | default: 3
-%}

<section class="ayva-ctl">
  <div class="ayva-ctl__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="ayva-ctl__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ayva-ctl__list">
      {%- for p in items limit: limit -%}
        {%- if p.id == product.id -%}{%- continue -%}{%- endif -%}
        {%- assign v = p.selected_or_first_available_variant -%}
        {%- assign p_on_sale = false -%}
        {%- if v.compare_at_price and v.compare_at_price > v.price -%}
          {%- assign p_on_sale = true -%}
        {%- endif -%}
        <article class="ayva-ctl__card">
          <a href="{{ p.url }}" class="ayva-ctl__media" aria-label="{{ p.title }}">
            {%- if p.featured_image -%}
              {{ p.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '200,400,600', sizes: '(min-width: 990px) 25vw, 50vw', alt: p.title }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </a>
          <div class="ayva-ctl__body">
            <a href="{{ p.url }}" class="ayva-ctl__title">{{ p.title }}</a>
            <div class="ayva-ctl__price">
              {%- if p_on_sale -%}
                <span class="ayva-price__sale">{{ v.price | money }}</span>
                <span class="ayva-price__compare">{{ v.compare_at_price | money }}</span>
              {%- else -%}
                <span class="ayva-price__sale">{{ v.price | money }}</span>
              {%- endif -%}
            </div>
            <form action="{{ routes.cart_add_url }}" method="post" class="ayva-ctl__form">
              <input type="hidden" name="id" value="{{ v.id }}">
              <button type="submit" class="ayva-btn ayva-btn--outline ayva-btn--sm"{% unless v.available %} disabled{% endunless %}>
                {% if v.available %}Add{% else %}Sold Out{% endif %}
              </button>
            </form>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AYVA Complete the Look",
  "tag": "section",
  "class": "section ayva-ctl-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Complete the look:" },
    { "type": "collection", "id": "collection", "label": "Product source collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 6, "step": 1, "default": 3 }
  ],
  "presets": [
    { "name": "AYVA Complete the Look" }
  ]
}
{% endschema %}
