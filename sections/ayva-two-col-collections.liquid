<!-- AYVA Two Column Collections: BIG OR SMALL section -->
{%- style -%}
  .ayva-twocol {
    max-width: 1440px;
    margin: 0 auto;
    padding: 16px 6rem 52px;
  }
  @media screen and (max-width: 749px) {
    .ayva-twocol {
      padding: 16px 1.5rem 36px;
    }
  }
  .ayva-twocol__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }
  @media screen and (max-width: 749px) {
    .ayva-twocol__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
  .ayva-twocol__item {
    text-decoration: none;
    color: #000;
    display: block;
  }
  .ayva-twocol__image {
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: #f0f0f0;
  }
  .ayva-twocol__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .ayva-twocol__item:hover .ayva-twocol__image img {
    transform: scale(1.05);
  }
  .ayva-twocol__title {
    font-family: var(--ayva-font-body);
    font-size: 1.3rem;
    font-weight: 400;
    margin-top: 1rem;
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }
{%- endstyle -%}

<section class="ayva-twocol">
  <div class="ayva-twocol__grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: '#' }}" class="ayva-twocol__item" {{ block.shopify_attributes }}>
        <div class="ayva-twocol__image">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '500,700,1000', sizes: '(min-width: 750px) 50vw, 100vw' }}
          {%- else -%}
            {{ 'collection-2' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
        <p class="ayva-twocol__title">{{ block.settings.title }}</p>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "AYVA Two Col Collections",
  "max_blocks": 2,
  "settings": [],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Collection image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AYVA Two Col Collections",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "title": "AYVA Everyday",
            "image_url": ""
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "AYVA Mini",
            "image_url": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
