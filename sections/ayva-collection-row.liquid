<!-- AYVA Collection Row: 4 collection cards with images -->
{%- style -%}
  .ayva-collections-row {
    padding: 28px 0 52px;
    max-width: 1440px;
    margin: 0 auto;
    padding-left: 6rem;
    padding-right: 6rem;
  }
  @media screen and (max-width: 749px) {
    .ayva-collections-row {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }
  .ayva-collections-row__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
  }
  @media screen and (max-width: 989px) {
    .ayva-collections-row__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (max-width: 749px) {
    .ayva-collections-row__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.8rem;
    }
  }
  .ayva-collections-row__item {
    text-decoration: none;
    color: #000;
    display: block;
  }
  .ayva-collections-row__image {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f0f0f0;
  }
  .ayva-collections-row__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .ayva-collections-row__item:hover .ayva-collections-row__image img {
    transform: scale(1.05);
  }
  .ayva-collections-row__title {
    font-family: var(--ayva-font-body);
    font-size: 1.3rem;
    font-weight: 400;
    margin-top: 1rem;
    text-decoration: none;
    color: #000;
  }
  .ayva-collections-row__title--underline {
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }
{%- endstyle -%}

<section class="ayva-collections-row">
  <div class="ayva-collections-row__grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: '#' }}" class="ayva-collections-row__item" {{ block.shopify_attributes }}>
        <div class="ayva-collections-row__image">
          <img
            src="{{ block.settings.image_url }}"
            alt="{{ block.settings.title }}"
            loading="lazy"
            width="540"
            height="540"
          >
        </div>
        <p class="ayva-collections-row__title{% if block.settings.underline %} ayva-collections-row__title--underline{% endif %}">
          {{ block.settings.title }}
        </p>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "AYVA Collection Row",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "underline",
          "label": "Underline title",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AYVA Collection Row",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "title": "All bags",
            "image_url": ""
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "NEW",
            "image_url": "",
            "underline": true
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Bag charms",
            "image_url": ""
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "AYVA Everyday",
            "image_url": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
