{{ 'ayva-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign items = section.settings.collection.products
  assign limit = section.settings.products_to_show
-%}

<section class="ayva-charms">
  <div class="ayva-charms__container">
    <div class="ayva-charms__header">
      <h2 class="ayva-charms__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.cta_link != blank -%}
        <a href="{{ section.settings.cta_link }}" class="ayva-charms__cta">{{ section.settings.cta_label }} →</a>
      {%- endif -%}
    </div>

    <div class="ayva-charms__grid">
      {%- for p in items limit: limit -%}
        {%- assign v = p.selected_or_first_available_variant -%}
        {%- assign p_on_sale = false -%}
        {%- if v.compare_at_price and v.compare_at_price > v.price -%}
          {%- assign p_on_sale = true -%}
        {%- endif -%}
        <article class="ayva-charms__card">
          <a href="{{ p.url }}" class="ayva-charms__media">
            {%- if p.featured_image -%}
              {{ p.featured_image | image_url: width: 500 | image_tag: loading: 'lazy', widths: '200,350,500', sizes: '(min-width: 990px) 16vw, 45vw', alt: p.title }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </a>
          <a href="{{ p.url }}" class="ayva-charms__title">{{ p.title }}</a>
          <div class="ayva-charms__price">
            {%- if p_on_sale -%}
              <span class="ayva-price__sale">{{ v.price | money }}</span>
              <span class="ayva-price__compare">{{ v.compare_at_price | money }}</span>
            {%- else -%}
              <span class="ayva-price__sale">{{ v.price | money }}</span>
            {%- endif -%}
          </div>
          <form action="{{ routes.cart_add_url }}" method="post" class="ayva-charms__form">
            <input type="hidden" name="id" value="{{ v.id }}">
            <button type="submit" class="ayva-btn ayva-btn--outline ayva-btn--sm"{% unless v.available %} disabled{% endunless %}>
              {% if v.available %}Quick add +{% else %}Sold Out{% endif %}
            </button>
          </form>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AYVA Charms Grid",
  "tag": "section",
  "class": "section ayva-charms-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "We love bag charms!" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop Now" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "collection", "id": "collection", "label": "Charm products collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 3, "max": 8, "step": 1, "default": 6 }
  ],
  "presets": [
    { "name": "AYVA Charms Grid" }
  ]
}
{% endschema %}
