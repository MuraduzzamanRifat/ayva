{%- liquid
  assign body_content = section.settings.content
  if body_content == blank
    assign body_content = page.content
  endif
-%}

<section class="ayva-policy">
  {%- if section.settings.eyebrow != blank -%}
    <p class="ayva-policy__eyebrow">{{ section.settings.eyebrow | escape }}</p>
  {%- endif -%}
  <h1 class="ayva-policy__heading">{{ section.settings.heading | default: page.title | escape }}</h1>
  {%- if section.settings.updated_date != blank -%}
    <p class="ayva-policy__meta">Last updated: {{ section.settings.updated_date | escape }}</p>
  {%- endif -%}
  <div class="ayva-policy__body rte">{{ body_content }}</div>
</section>

{% schema %}
{
  "name": "AYVA Policy Page",
  "tag": "section",
  "class": "section ayva-policy-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (small label above heading)" },
    { "type": "text", "id": "heading", "label": "Heading (leave blank to use page title)" },
    { "type": "text", "id": "updated_date", "label": "Last-updated date (e.g. 1 April 2026)" },
    { "type": "html", "id": "content", "label": "Body content — leave blank to use the page's own content from Shopify admin. Supports H2/H3/UL/OL/links.", "info": "For policies, best practice is to leave this empty and write the content in Shopify admin → Pages. Fill this only if you want a policy-specific override." }
  ],
  "presets": [
    { "name": "AYVA Policy Page" }
  ]
}
{% endschema %}
