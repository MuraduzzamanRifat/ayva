{%- style -%}
  .ayva-policy {
    max-width: 820px;
    margin: 0 auto;
    padding: 64px 20px 80px;
    color: var(--ayva-fg, #0a0a0a);
    font-family: var(--font-body-family, 'Inter', -apple-system, sans-serif);
  }
  @media (min-width: 750px) {
    .ayva-policy { padding: 96px 40px 112px; }
  }
  .ayva-policy__eyebrow {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ayva-fg-3, #666);
    margin: 0 0 12px;
  }
  .ayva-policy__heading {
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0 0 8px;
  }
  @media (min-width: 750px) {
    .ayva-policy__heading { font-size: 40px; }
  }
  .ayva-policy__meta {
    font-size: 13px;
    color: var(--ayva-fg-3, #666);
    margin: 0 0 40px;
  }
  .ayva-policy__body {
    font-size: 15px;
    line-height: 1.75;
    color: var(--ayva-fg-2, #333);
  }
  .ayva-policy__body h2 {
    font-size: 20px;
    font-weight: 600;
    color: var(--ayva-fg, #0a0a0a);
    margin: 40px 0 12px;
    letter-spacing: -0.005em;
  }
  .ayva-policy__body h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 28px 0 8px;
  }
  .ayva-policy__body p { margin: 0 0 16px; }
  .ayva-policy__body ul,
  .ayva-policy__body ol { margin: 0 0 16px; padding-left: 22px; }
  .ayva-policy__body li { margin: 0 0 6px; }
  .ayva-policy__body a { color: var(--ayva-fg, #0a0a0a); text-decoration: underline; text-underline-offset: 3px; }
  .ayva-policy__body a:hover { text-decoration-thickness: 2px; }
  .ayva-policy__body strong { color: var(--ayva-fg, #0a0a0a); font-weight: 600; }
  .ayva-policy__body hr { border: 0; border-top: 1px solid #e6e6e6; margin: 40px 0; }
{%- endstyle -%}

<section class="ayva-policy">
  {%- if section.settings.eyebrow != blank -%}
    <p class="ayva-policy__eyebrow">{{ section.settings.eyebrow | escape }}</p>
  {%- endif -%}
  <h1 class="ayva-policy__heading">{{ section.settings.heading | escape }}</h1>
  {%- if section.settings.updated_date != blank -%}
    <p class="ayva-policy__meta">Last updated: {{ section.settings.updated_date | escape }}</p>
  {%- endif -%}
  <div class="ayva-policy__body rte">{{ section.settings.content }}</div>
</section>

{% schema %}
{
  "name": "AYVA Policy Page",
  "tag": "section",
  "class": "section ayva-policy-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (small label above heading)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page title" },
    { "type": "text", "id": "updated_date", "label": "Last-updated date (e.g. 1 April 2026)" },
    { "type": "richtext", "id": "content", "label": "Body content (supports H2/H3/lists/links)", "default": "<p>Content goes here.</p>" }
  ],
  "presets": [
    { "name": "AYVA Policy Page" }
  ]
}
{% endschema %}
