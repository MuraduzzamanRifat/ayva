{%- liquid
  assign total = section.settings.total_reviews | plus: 0
  assign avg = section.settings.average_rating
  assign r5 = section.settings.pct_5 | plus: 0
  assign r4 = section.settings.pct_4 | plus: 0
  assign r3 = section.settings.pct_3 | plus: 0
  assign r2 = section.settings.pct_2 | plus: 0
  assign r1 = section.settings.pct_1 | plus: 0
-%}

<section class="ayva-reviews">
  <div class="ayva-reviews__container">
    <h2 class="ayva-reviews__heading">{{ section.settings.heading }}</h2>

    <div class="ayva-reviews__summary">
      <div class="ayva-reviews__avg">
        <span class="ayva-stars" aria-hidden="true">
          {%- for i in (1..5) -%}<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 17.27l5.18 3.73-1.64-6.36L20.55 9.5l-6.45-.57L12 3 9.9 8.93 3.45 9.5l5.01 5.14L6.82 21z"/></svg>{%- endfor -%}
        </span>
        <div>
          <strong>{{ avg }}</strong>
          <span>Based on {{ total }} review{% if total != 1 %}s{% endif %}</span>
        </div>
      </div>

      <div class="ayva-reviews__bars">
        {%- assign pairs = '5,' | append: r5 | append: '|4,' | append: r4 | append: '|3,' | append: r3 | append: '|2,' | append: r2 | append: '|1,' | append: r1 -%}
        {%- assign rows = pairs | split: '|' -%}
        {%- for row in rows -%}
          {%- assign parts = row | split: ',' -%}
          {%- assign star = parts[0] -%}
          {%- assign pct = parts[1] -%}
          <div class="ayva-reviews__bar">
            <span class="ayva-reviews__bar-label">{{ star }} ★</span>
            <span class="ayva-reviews__bar-track"><span class="ayva-reviews__bar-fill" style="width: {{ pct }}%"></span></span>
            <span class="ayva-reviews__bar-pct">{{ pct }}%</span>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.write_review_url != blank -%}
        <a href="{{ section.settings.write_review_url }}" class="ayva-btn ayva-btn--outline ayva-btn--sm">Write a review</a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="ayva-reviews__list">
        {%- for block in section.blocks -%}
          <article class="ayva-reviews__item" {{ block.shopify_attributes }}>
            <header>
              <span class="ayva-stars" aria-hidden="true">
                {%- for i in (1..5) -%}
                  <svg viewBox="0 0 24 24" fill="{% if forloop.index <= block.settings.stars %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1" width="14" height="14"><path d="M12 17.27l5.18 3.73-1.64-6.36L20.55 9.5l-6.45-.57L12 3 9.9 8.93 3.45 9.5l5.01 5.14L6.82 21z"/></svg>
                {%- endfor -%}
              </span>
              <strong>{{ block.settings.author | default: 'Anonymous' }}</strong>
            </header>
            <p>{{ block.settings.body }}</p>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "AYVA Reviews",
  "tag": "section",
  "class": "section ayva-reviews-section",
  "max_blocks": 20,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Customer Reviews" },
    { "type": "text", "id": "average_rating", "label": "Average rating", "default": "4.87" },
    { "type": "number", "id": "total_reviews", "label": "Total reviews", "default": 1 },
    { "type": "header", "content": "Rating breakdown (%)" },
    { "type": "number", "id": "pct_5", "label": "5 star %", "default": 100 },
    { "type": "number", "id": "pct_4", "label": "4 star %", "default": 0 },
    { "type": "number", "id": "pct_3", "label": "3 star %", "default": 0 },
    { "type": "number", "id": "pct_2", "label": "2 star %", "default": 0 },
    { "type": "number", "id": "pct_1", "label": "1 star %", "default": 0 },
    { "type": "url", "id": "write_review_url", "label": "Write review link" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "author", "label": "Author", "default": "Anonymous" },
        { "type": "range", "id": "stars", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "body", "label": "Review text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AYVA Reviews",
      "blocks": [
        { "type": "review", "settings": { "author": "Anonymous", "stars": 5, "body": "so cuteeee" } }
      ]
    }
  ]
}
{% endschema %}
