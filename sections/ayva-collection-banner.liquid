<!-- AYVA Collection Banner: horizontal lifestyle image strip -->
{%- style -%}
  .ayva-col-banner {
    width: 100%;
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .ayva-col-banner__strip {
    display: flex;
    gap: 0;
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .ayva-col-banner__strip::-webkit-scrollbar {
    display: none;
  }
  .ayva-col-banner__img {
    flex: 0 0 auto;
    width: 20%;
    min-width: 200px;
    aspect-ratio: 3/4;
    overflow: hidden;
  }
  @media screen and (max-width: 749px) {
    .ayva-col-banner__img {
      width: 40%;
      min-width: 150px;
    }
  }
  .ayva-col-banner__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
{%- endstyle -%}

<section class="ayva-col-banner">
  <div class="ayva-col-banner__strip">
    {% for block in section.blocks %}
      <div class="ayva-col-banner__img" {{ block.shopify_attributes }}>
        <img
          src="{{ block.settings.image_url }}"
          alt="AYVA lifestyle"
          loading="eager"
          width="400"
          height="533"
        >
      </div>
    {% endfor %}
  </div>
</section>

