{%- style -%}
  .ayva-about { width: 100%; }

  .ayva-about__hero {
    width: 100%;
    aspect-ratio: 16/9;
    max-height: 70vh;
    min-height: 360px;
    overflow: hidden;
    background: #f0ede8;
    margin: 0;
  }
  .ayva-about__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ayva-about__section {
    max-width: 750px;
    margin: 0 auto;
    padding: 80px 20px;
    text-align: center;
  }
  @media (min-width: 750px) {
    .ayva-about__section { padding: 96px 40px; }
  }

  .ayva-about__heading {
    font-family: inherit;
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.15;
    color: #000;
    margin: 0 0 32px;
  }
  @media (min-width: 750px) {
    .ayva-about__heading { font-size: 32px; }
  }

  .ayva-about__text {
    font-family: inherit;
    font-size: 15px;
    line-height: 1.8;
    color: #333;
    margin: 0 0 24px;
  }
  .ayva-about__text:last-child { margin-bottom: 0; }
  .ayva-about__text em {
    font-style: italic;
    color: #111;
  }

  .ayva-about__image-divider {
    width: 100%;
    aspect-ratio: 16/9;
    max-height: 56vh;
    overflow: hidden;
    background: #f0ede8;
    margin: 0;
  }
  .ayva-about__image-divider img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ayva-about__collections {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px 80px;
  }
  @media (min-width: 750px) {
    .ayva-about__collections { padding: 80px 40px 96px; }
  }
  .ayva-about__collections-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 750px) {
    .ayva-about__collections-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }
  }
  .ayva-about__col-card {
    text-decoration: none;
    color: #000;
    display: block;
  }
  .ayva-about__col-image {
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
    background: #f0f0f0;
  }
  .ayva-about__col-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .ayva-about__col-card:hover .ayva-about__col-image img {
    transform: scale(1.04);
  }
  .ayva-about__col-title {
    font-family: inherit;
    font-size: 16px;
    font-weight: 600;
    color: #000;
    margin: 16px 0 0;
    text-align: center;
  }
{%- endstyle -%}

<div class="ayva-about">

  {%- if section.settings.hero_image != blank -%}
    <div class="ayva-about__hero">
      {{
        section.settings.hero_image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '800,1200,1600,2000,2400',
          sizes: '100vw',
          alt: section.settings.section1_heading | escape
      }}
    </div>
  {%- endif -%}

  <div class="ayva-about__section">
    <h1 class="ayva-about__heading">{{ section.settings.section1_heading | default: 'AYVA BAGS' | escape }}</h1>
    {%- if section.settings.section1_text1 != blank -%}
      <p class="ayva-about__text">{{ section.settings.section1_text1 }}</p>
    {%- endif -%}
    {%- if section.settings.section1_text2 != blank -%}
      <p class="ayva-about__text">{{ section.settings.section1_text2 }}</p>
    {%- endif -%}
    {%- if section.settings.section1_text3 != blank -%}
      <p class="ayva-about__text">{{ section.settings.section1_text3 }}</p>
    {%- endif -%}
  </div>

  {%- if section.settings.image_divider_1 != blank -%}
    <div class="ayva-about__image-divider">
      {{ section.settings.image_divider_1 | image_url: width: 2400 | image_tag: loading: 'lazy', widths: '800,1200,1600,2000,2400', sizes: '100vw', alt: '' }}
    </div>
  {%- endif -%}

  <div class="ayva-about__section">
    <h2 class="ayva-about__heading">{{ section.settings.section2_heading | default: 'Our Mission' | escape }}</h2>
    {%- if section.settings.section2_text1 != blank -%}
      <p class="ayva-about__text">{{ section.settings.section2_text1 }}</p>
    {%- endif -%}
    {%- if section.settings.section2_text2 != blank -%}
      <p class="ayva-about__text">{{ section.settings.section2_text2 }}</p>
    {%- endif -%}
    {%- if section.settings.section2_text3 != blank -%}
      <p class="ayva-about__text">{{ section.settings.section2_text3 }}</p>
    {%- endif -%}
  </div>

  {%- if section.settings.image_divider_2 != blank -%}
    <div class="ayva-about__image-divider">
      {{ section.settings.image_divider_2 | image_url: width: 2400 | image_tag: loading: 'lazy', widths: '800,1200,1600,2000,2400', sizes: '100vw', alt: '' }}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="ayva-about__collections">
      <div class="ayva-about__collections-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'collection_card' -%}
            <a href="{{ block.settings.link | default: '#' }}" class="ayva-about__col-card" {{ block.shopify_attributes }}>
              <div class="ayva-about__col-image">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300,500,800', sizes: '(min-width: 750px) 33vw, 100vw', alt: block.settings.title | escape }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag }}
                {%- endif -%}
              </div>
              <p class="ayva-about__col-title">{{ block.settings.title | escape }}</p>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "AYVA About Page",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image (full-bleed, 16:9)" },

    { "type": "header", "content": "Section 1" },
    { "type": "text", "id": "section1_heading", "label": "Heading", "default": "AYVA BAGS" },
    { "type": "textarea", "id": "section1_text1", "label": "Paragraph 1" },
    { "type": "textarea", "id": "section1_text2", "label": "Paragraph 2" },
    { "type": "textarea", "id": "section1_text3", "label": "Paragraph 3" },

    { "type": "header", "content": "Image between sections (optional)" },
    { "type": "image_picker", "id": "image_divider_1", "label": "Full-bleed image between Section 1 and 2" },

    { "type": "header", "content": "Section 2" },
    { "type": "text", "id": "section2_heading", "label": "Heading", "default": "Our Mission" },
    { "type": "textarea", "id": "section2_text1", "label": "Paragraph 1" },
    { "type": "textarea", "id": "section2_text2", "label": "Paragraph 2" },
    { "type": "textarea", "id": "section2_text3", "label": "Paragraph 3" },

    { "type": "header", "content": "Image before collection grid (optional)" },
    { "type": "image_picker", "id": "image_divider_2", "label": "Full-bleed image before collection grid" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image (1:1 square)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AYVA About Page",
      "blocks": [
        { "type": "collection_card", "settings": { "title": "New Arrivals" } },
        { "type": "collection_card", "settings": { "title": "All bags" } },
        { "type": "collection_card", "settings": { "title": "Bag charms" } }
      ]
    }
  ]
}
{% endschema %}
