{{ 'ayva-product.css' | asset_url | stylesheet_tag }}

<section class="ayva-faq">
  <div class="ayva-faq__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="ayva-faq__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ayva-faq__list">
      {%- for block in section.blocks -%}
        <details class="ayva-faq__item" {{ block.shopify_attributes }}>
          <summary>
            <span>{{ block.settings.question }}</span>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" class="ayva-faq__chev"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="ayva-faq__body rte">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AYVA FAQ",
  "tag": "section",
  "class": "section ayva-faq-section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "AYVA FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "Does it feel high quality in real life?", "answer": "<p>Yes — we obsess over materials. Every bag is crafted in smooth vegan leather with solid metal hardware. Customers regularly tell us it feels far more premium than the price suggests.</p>" } },
        { "type": "faq", "settings": { "question": "Will it fit my everyday essentials?", "answer": "<p>Absolutely. Our bags are designed to comfortably hold your phone, wallet, keys, sunglasses, and small makeup pouch — with room to spare.</p>" } },
        { "type": "faq", "settings": { "question": "Is AYVA a real and safe brand to order from?", "answer": "<p>100%. AYVA is a registered Swedish company (AOE Ecom AB, Reg# 559458-2925). We ship worldwide, offer a 30-day money-back guarantee, and have served 100,000+ customers.</p>" } },
        { "type": "faq", "settings": { "question": "What if the color looks different in real life?", "answer": "<p>Colors are photographed in natural light and can vary slightly by monitor. If the color isn't what you expected, return within 30 days for a full refund.</p>" } },
        { "type": "faq", "settings": { "question": "Why is the price this level?", "answer": "<p>We sell direct — no middlemen, no department-store markup. You get designer-level quality at a fraction of the cost.</p>" } },
        { "type": "faq", "settings": { "question": "What if I change my mind after ordering?", "answer": "<p>No stress. You have 30 days from delivery to return for a full refund. Reach out to hey@ayvaofficial.com and we'll handle it.</p>" } }
      ]
    }
  ]
}
{% endschema %}
