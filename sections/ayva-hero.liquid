{%- style -%}
  #AyvaHero-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    min-height: {{ section.settings.min_height_desktop }}vh;
    display: flex;
    align-items: stretch;
  }
  @media (max-width: 749px) {
    #AyvaHero-{{ section.id }} {
      min-height: {{ section.settings.min_height_mobile }}vh;
    }
  }
  #AyvaHero-{{ section.id }} .ayva-hero__image {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
  }
  #AyvaHero-{{ section.id }} .ayva-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #AyvaHero-{{ section.id }} .ayva-hero__cta {
    position: relative;
    margin: auto;
    z-index: 2;
    background: rgba(255, 255, 255, 0.95);
    padding: 20px 40px;
    text-align: center;
  }
  @media (max-width: 749px) {
    #AyvaHero-{{ section.id }} .ayva-hero__cta {
      padding: 16px 32px;
    }
  }
  #AyvaHero-{{ section.id }} .ayva-hero__btn {
    display: inline-block;
    font-family: inherit;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #000;
    background: transparent;
    border: 2px solid #000;
    padding: 14px 40px;
    text-decoration: none;
    transition: background .2s, color .2s;
  }
  #AyvaHero-{{ section.id }} .ayva-hero__btn:hover {
    background: #000;
    color: #fff;
  }
  #AyvaHero-{{ section.id }} .ayva-hero__placeholder {
    width: 100%;
    min-height: 60vh;
    background: #f0ede8;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
{%- endstyle -%}

<section id="AyvaHero-{{ section.id }}" class="ayva-hero{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="ayva-hero__image">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '800,1200,1600,2000,2400',
          sizes: '100vw',
          alt: section.settings.image.alt | default: shop.name | escape
      }}
    {%- else -%}
      <div class="ayva-hero__placeholder">Upload hero image in theme editor</div>
    {%- endif -%}
  </div>
  {%- if section.settings.button_text != blank -%}
    <div class="ayva-hero__cta">
      <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="ayva-hero__btn">
        {{ section.settings.button_text | escape }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "AYVA Hero Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image (single full-width)" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "SHOP NOW" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "range", "id": "min_height_desktop", "label": "Desktop height (vh)", "min": 50, "max": 100, "step": 5, "default": 85, "unit": "vh" },
    { "type": "range", "id": "min_height_mobile", "label": "Mobile height (vh)", "min": 40, "max": 100, "step": 5, "default": 60, "unit": "vh" }
  ],
  "presets": [
    { "name": "AYVA Hero Banner" }
  ]
}
{% endschema %}
