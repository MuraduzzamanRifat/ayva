{%- style -%}
  #AyvaHero-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    min-height: {{ section.settings.min_height_desktop }}vh;
    display: flex;
    align-items: stretch;
  }
  @media (max-width: 749px) {
    #AyvaHero-{{ section.id }} {
      min-height: {{ section.settings.min_height_mobile }}vh;
    }
  }
  #AyvaHero-{{ section.id }} .ayva-hero__image {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
  }
  #AyvaHero-{{ section.id }} .ayva-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #AyvaHero-{{ section.id }} .ayva-hero__cta {
    position: relative;
    margin: auto;
    z-index: 2;
    text-align: center;
  }
  #AyvaHero-{{ section.id }} .ayva-hero__btn {
    display: inline-block;
    font-family: inherit;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #fff;
    background: transparent;
    border: 1px solid #fff;
    padding: 10px 26px;
    text-decoration: none;
    transition: background .25s ease, color .25s ease;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }
  #AyvaHero-{{ section.id }} .ayva-hero__btn:hover {
    background: #fff;
    color: #000;
    text-shadow: none;
  }
  #AyvaHero-{{ section.id }} .ayva-hero__placeholder {
    width: 100%;
    min-height: 60vh;
    background: #f0ede8;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
{%- endstyle -%}

<section id="AyvaHero-{{ section.id }}" class="ayva-hero{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="ayva-hero__image">
    {%- if section.settings.image == blank and section.settings.image_url == blank -%}
      <div class="ayva-hero__placeholder">Upload hero image in theme editor</div>
    {%- else -%}
      {%- assign _hero_alt = section.settings.image.alt | default: shop.name -%}
      {%- render 'ayva-image',
        picker: section.settings.image,
        url: section.settings.image_url,
        placeholder: 'lifestyle-1',
        alt: _hero_alt,
        widths: '800,1200,1600,2000,2400',
        sizes: '100vw',
        loading: 'eager',
        fetchpriority: 'high',
        width: 2400,
        height: 1350 -%}
    {%- endif -%}
  </div>
  {%- if section.settings.button_text != blank -%}
    <div class="ayva-hero__cta">
      <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="ayva-hero__btn">
        {{ section.settings.button_text | escape }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "AYVA Hero Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image (preferred — upload)" },
    { "type": "text", "id": "image_url", "label": "Fallback hero image URL", "info": "Free stock: pexels.com. Used when no image uploaded." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "SHOP NOW" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "range", "id": "min_height_desktop", "label": "Desktop height (vh)", "min": 50, "max": 100, "step": 5, "default": 85, "unit": "vh" },
    { "type": "range", "id": "min_height_mobile", "label": "Mobile height (vh)", "min": 40, "max": 100, "step": 5, "default": 60, "unit": "vh" }
  ],
  "presets": [
    { "name": "AYVA Hero Banner" }
  ]
}
{% endschema %}
