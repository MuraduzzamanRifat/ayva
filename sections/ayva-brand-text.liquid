{%- style -%}
  #AyvaBrandText-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    text-align: {{ section.settings.text_alignment }};
  }
  #AyvaBrandText-{{ section.id }} .ayva-brand-text__wrapper {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (min-width: 750px) {
    #AyvaBrandText-{{ section.id }} .ayva-brand-text__wrapper { padding: 0 40px; }
  }
  #AyvaBrandText-{{ section.id }} .ayva-brand-text__eyebrow {
    font-family: inherit;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 12px;
    margin: 0 0 12px;
    color: {{ section.settings.text_color }};
    opacity: 0.6;
  }
  #AyvaBrandText-{{ section.id }} .ayva-brand-text__heading {
    font-family: inherit;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1.15;
    margin: 0;
    color: {{ section.settings.text_color }};
    {% case section.settings.text_size %}
      {% when 'small' %}
        font-size: clamp(20px, 3vw, 28px);
      {% when 'medium' %}
        font-size: clamp(28px, 5vw, 44px);
      {% when 'large' %}
        font-size: clamp(36px, 7vw, 64px);
    {% endcase %}
  }
  #AyvaBrandText-{{ section.id }} .ayva-brand-text__body {
    font-family: inherit;
    font-size: 16px;
    line-height: 1.7;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
    margin: 24px auto 0;
    max-width: 680px;
  }
  #AyvaBrandText-{{ section.id }} .ayva-brand-text__body p { margin: 0 0 12px; }
  #AyvaBrandText-{{ section.id }} .ayva-brand-text__body p:last-child { margin-bottom: 0; }
  #AyvaBrandText-{{ section.id }} .ayva-brand-text__btn {
    display: inline-block;
    font-family: inherit;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: {{ section.settings.text_color }};
    background: transparent;
    border: 2px solid {{ section.settings.text_color }};
    padding: 14px 36px;
    margin-top: 28px;
    text-decoration: none;
    transition: background .2s, color .2s;
  }
  #AyvaBrandText-{{ section.id }} .ayva-brand-text__btn:hover {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background_color }};
  }
{%- endstyle -%}

<section
  id="AyvaBrandText-{{ section.id }}"
  class="ayva-brand-text{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
  aria-label="{{ section.settings.heading | default: 'Brand message' | escape }}"
>
  <div class="ayva-brand-text__wrapper"{% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}>
    {%- if section.settings.eyebrow != blank -%}
      <p class="ayva-brand-text__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="ayva-brand-text__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="ayva-brand-text__body rte">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link | default: '#' }}" class="ayva-brand-text__btn">
        {{ section.settings.button_text | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "AYVA Brand Text",
  "tag": "section",
  "class": "section-ayva-brand-text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (small uppercase above heading)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "SHAPES FOR EVERY MOMENT" },
    { "type": "richtext", "id": "body", "label": "Body copy (optional)" },
    { "type": "text", "id": "button_text", "label": "Button text (optional)" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select", "id": "text_size", "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large"
    },
    {
      "type": "select", "id": "text_alignment", "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#000000" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [
    {
      "name": "AYVA Brand Text",
      "settings": {
        "heading": "SHAPES FOR EVERY MOMENT",
        "text_size": "large",
        "text_alignment": "center"
      }
    }
  ]
}
{% endschema %}
